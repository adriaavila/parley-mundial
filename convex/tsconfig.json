{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": []
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
